{
  "expo": {
    "scheme": "forge",
    "experiments": {
      "typedRoutes": true
    },
    "name": "forge",
    "slug": "forge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/forge-logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/forge-logo.png",
        "backgroundImage": "./assets/images/forge-logo.png",
        "monochromeImage": "./assets/images/forge-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.roni.dev.forge"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router",
      "expo-status-bar"
    ]
  }
}
