{
  "expo": {
    "scheme": "forge",
    "experiments": {
      "typedRoutes": true
    },
    "name": "forge",
    "slug": "forge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/forge-logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/forge-logo.png",
        "backgroundImage": "./assets/images/forge-logo.png",
        "monochromeImage": "./assets/images/forge-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.roni.dev.forge",
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router",
      "expo-status-bar",
      "expo-audio",
      [
        "react-native-notify-kit",
        {
          "android": {
            "foregroundService": {
              "types": [
                "health"
              ]
            }
          }
        }
      ],
      "expo-splash-screen",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a75f6e02-bc1c-48c5-b49d-bcdb432072ae"
      }
    }
  }
}
